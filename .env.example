# Local development defaults
#
# Copy this file to .env or set these variables in your shell. Do not commit real
# secrets or production values.

# API server port. The Replit config routes this app from 8080.
PORT=8080

# Vite base path for the PWA during local development.
BASE_PATH=/

# Frontend dev server port used by the API server proxy in development.
VITE_PORT=24245

# Replit/Object Storage private directory for uploaded media.
# Required for upload + Whisper processing routes.
# Example shape: /bucket-name/private
PRIVATE_OBJECT_DIR=

# Public object search paths, only needed if public object lookup routes are used.
# Comma-separated object storage paths.
# Example shape: /bucket-name/public
PUBLIC_OBJECT_SEARCH_PATHS=

# Required only for optional Arabic dubbing and voice preview features.
ELEVENLABS_API_KEY=

# Required only for Drizzle/Postgres DB tooling and code that imports lib/db.
DATABASE_URL=
