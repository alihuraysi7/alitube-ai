{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:api": "node ./scripts/dev.mjs api",
    "dev:web": "node ./scripts/dev.mjs web",
    "kill-port": "node ./scripts/kill-port.mjs",
    "preinstall": "node ./scripts/require-pnpm.mjs",
    "build": "corepack pnpm run typecheck && corepack pnpm -r --if-present run build",
    "start": "corepack pnpm --filter @workspace/api-server run start",
    "typecheck:libs": "tsc --build",
    "typecheck": "corepack pnpm run typecheck:libs && corepack pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
