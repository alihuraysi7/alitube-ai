  },
  {
    "start": 18.64,
    "duration": 3.24,
    "text": "♪ نحن لسنا غرباء لنحب ♪"
  },
  {
    "start": 22.64,
    "duration": 4.32,
    "text": "♪ أنت تعرف القواعد وأنا أيضًا ♪"
  },
  {
    "start": 27.04,
    "duration": 4,
    "text": "♪ الالتزام الكامل هو ما أفكر فيه ♪"
  },
  {
    "start": 31.12,
    "duration": 3.96,
    "text": "♪ لن تحصل على هذا من أي شخص آخر ♪"
  },
  {
    "start": 35.16,
    "duration": 4.36,
    "text": "♪ أريد فقط أن أخبرك بما أشعر به ♪"
  },
  {
    "start": 40.52,
    "duration": 2.4,
    "text": "♪ يجب أن أجعلك تفهم ♪"
  },
  {
    "start": 43,
    "duration": 2.12,
    "text": "♪ لن أتخلى عنك أبدًا ♪"
  },
  {
    "start": 45.2,
    "duration": 1.88,
    "text": "♪ لن نخذلكم أبدًا ♪"
  },
  {
    "start": 47.32,
    "duration": 3.8,
    "text": "♪ لن أركض وأهجرك أبدًا ♪"
  },
  {
    "start": 51.48,
    "duration": 2,
    "text": "♪ لن تجعلك تبكي أبدًا ♪"
  },
  {
    "start": 53.6,
    "duration": 1.92,
    "text": "♪ لن أقول وداعاً أبداً ♪"
  },
  {
    "start": 55.72,
    "duration": 3.64,
    "text": "♪ لن تكذب أبدًا وتؤذيك ♪"
  },
  {
    "start": 60.8,
    "duration": 4,
    "text": "♪ لقد عرفنا بعضنا البعض لفترة طويلة ♪"
  },
  {
    "start": 64.88,
    "duration": 4.16,
    "text": "♪ كان قلبك يؤلمك ولكنك خجول جدًا من قول ذلك ♪"
  },
  {
    "start": 69.12,
    "duration": 3.84,
    "text": "♪ في الداخل، كلانا يعرف ما يحدث ♪"
  },
  {
