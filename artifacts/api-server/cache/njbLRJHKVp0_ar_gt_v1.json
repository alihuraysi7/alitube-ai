[
  {
    "start": 3.12,
    "duration": 6.8,
    "text": "ويفر،"
  },
  {
    "start": 4.64,
    "duration": 8.16,
    "text": "في الجزء الثامن، آخر سطر لهم،"
  },
  {
    "start": 9.92,
    "duration": 3.96,
    "text": "ضعيف مع تقدم العمر."
  },
  {
    "start": 12.8,
    "duration": 4.44,
    "text": ">> توقف، [ضحك]"
  },
  {
    "start": 13.88,
    "duration": 6.04,
    "text": "المتجول من النفايات. تم العثور عليك"
  },
  {
    "start": 17.24,
    "duration": 6.04,
    "text": "مذنب من أحفاده."
  },
  {
    "start": 19.92,
    "duration": 7.32,
    "text": "لقد تعقبنا خطك بالكامل."
  },
  {
    "start": 23.28,
    "duration": 4.8,
    "text": "أنت فقط تعيش إلى هذا العمر. لا تهدر"
  },
  {
    "start": 27.24,
    "duration": 4,
    "text": "ذلك."
  },
  {
    "start": 28.08,
    "duration": 5.48,
    "text": "إرسال وتطهير نفسك وإرسالها إلى"
  },
  {
    "start": 31.24,
    "duration": 6.36,
    "text": "القلعة المقدسة."
  },
  {
    "start": 33.56,
    "duration": 4.04,
    "text": ">> لن يكون لديك أنا."
  },
  {
    "start": 41.4,
    "duration": 6.04,
    "text": ">> لذلك، اخترت [موسيقى] الموت."
  },
  {
    "start": 44.72,
    "duration": 2.72,
    "text": "الهجوم."
  },
  {
    "start": 49.84,
    "duration": 4.28,
    "text": "حريرها. التقطه."
  },
  {
    "start": 61.28,
    "duration": 2.68,
    "text": ">> الآنسة."
  },
  {
    "start": 71,
    "duration": 7,
    "text": "أبداً."
  },
  {
    "start": 72.92,
    "duration": 7.56,
    "text": ">> كما قلت من قبل، قدم لفارلوك."
  },
  {
    "start": 78,
    "duration": 6.36,
    "text": "تستمر في المقاومة."
  },
  {
    "start": 80.48,
    "duration": 6.4,
    "text": "إنه عديم الفائدة. أنا أعرف ما أنت عليه،"
  },
  {
    "start": 84.36,
    "duration": 6.88,
    "text": "حائك."
  },
  {
    "start": 86.88,
    "duration": 5.32,
    "text": ">> كانت أمهات أجدادي كذلك. أنت لا تعرف شيئًا عن"
  },
  {
    "start": 91.24,
    "duration": 4.32,
    "text": "أنا."
  },
  {
    "start": 92.2,
    "duration": 5.8,
    "text": ">> أنت لا تهم أيها المرتد. أنت تنتج"
  },
  {
    "start": 95.56,
    "duration": 5.04,
    "text": "حرير، ولكن لا يمكن ربطه."
  },
  {
    "start": 98,
    "duration": 5.84,
    "text": "أنت كبير جدًا في السن، والدماء مشوشة جدًا"
  },
  {
    "start": 100.6,
    "duration": 6.16,
    "text": "حشرة أقل. بدلاً من ذلك، أنت بحماقة"
  },
  {
    "start": 103.84,
    "duration": 5.8,
    "text": "تجلت روحك إلى الخارج."
  },
  {
    "start": 106.76,
    "duration": 5,
    "text": "أصبح قلبك الحريري عكازًا،"
  },
  {
    "start": 109.64,
    "duration": 6.88,
    "text": "مجرد عصا للمشي."
  },
  {
    "start": 111.76,
    "duration": 4.76,
    "text": "إذا أخذتها، ستموت."
  },
  {
    "start": 117,
    "duration": 4.8,
    "text": "لكنها لن تفعل ذلك."
  },
  {
    "start": 119.4,
    "duration": 5.28,
    "text": "نحن بحاجة لكم سليمة."
  },
  {
    "start": 121.8,
    "duration": 7.48,
    "text": "لدى فارلم خطط كبيرة لك."
  },
  {
    "start": 124.68,
    "duration": 7.6,
    "text": "بعد كل شيء، يجب على الخلل الذي يخدم ألا"
  },
  {
    "start": 129.28,
    "duration": 3,
    "text": "الموت."
  }
]